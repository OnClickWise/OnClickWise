# ============================================
# FRONTEND CONFIGURATION (Next.js)
# ============================================

# Porta que o servidor frontend Next.js vai ouvir
# O Next.js lê esta variável automaticamente - não é necessário passar como flag
# Exemplo: Se você definir PORT=3001, o frontend estará disponível em http://localhost:3001
# Padrão: 3000 (se não definido) - Recomendado: 3001 para evitar conflito com o backend
PORT=3001

# ============================================
# BACKEND API CONFIGURATION
# ============================================

# URL completa do backend API (servidor Node.js)
# Esta é a URL que o frontend usa para fazer requisições ao backend
# IMPORTANTE: Inclua o protocolo (http:// ou https://) e a porta
# Exemplo para desenvolvimento local: http://localhost:3000
# Exemplo para produção: https://api.seudominio.com
NEXT_PUBLIC_API_URL=http://localhost:3002

# ============================================
# ENVIRONMENT SETTINGS
# ============================================

# Ambiente de execução: development, production, ou test
NODE_ENV=development
